<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>Monthly Reconciliation Report</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      font-size: 12pt;
      color: #222;
      background: #fff;
      margin: 0;
      padding: 0;
    }
    .header {
      background: #f8f9fa;
      padding: 18px 24px;
      border-bottom: 1px solid #dee2e6;
    }
    .title {
      font-size: 18pt;
      font-weight: bold;
      color: #1e3a8a;
      margin-bottom: 8px;
    }
    .period {
      font-size: 12pt;
      color: #333;
      margin-bottom: 8px;
    }
    .summary {
      margin: 24px 0;
      background: #f8f9fa;
      border: 1px solid #dee2e6;
      border-radius: 6px;
      padding: 18px 24px;
    }
    .summary-row {
      margin-bottom: 10px;
    }
    .summary-label {
      font-weight: bold;
      color: #333;
      margin-right: 10px;
    }
    .summary-value {
      color: #1e3a8a;
    }
    .files-section {
      margin: 24px 0;
    }
    .file-link {
      display: block;
      margin-bottom: 10px;
      font-size: 12pt;
      color: #007bff;
      text-decoration: underline;
    }
    .footer {
      margin-top: 40px;
      font-size: 10pt;
      color: #666;
      text-align: center;
      border-top: 1px solid #ccc;
      padding-top: 12px;
    }
  </style>
</head>
<body>
  <div class="header">
    <div class="title">Monthly Reconciliation Report</div>
    <div class="period">Period: <%= reportPeriod %></div>
    <div>State: <%= stateName %></div>
  </div>
  <div class="summary">
    <div class="summary-row">
      <span class="summary-label">Monthly SASP Net Fees in Pennies:</span>
      <span class="summary-value"><%= monthlySaspNetFees %></span>
    </div>
    <div class="summary-row">
      <span class="summary-label">Monthly American Surplus Net Fees in Pennies:</span>
      <span class="summary-value"><%= monthlyAmericanSurplusNetFees %></span>
    </div>
    <div class="summary-row">
      <span class="summary-label">Total Monthly Fees:</span>
      <span class="summary-value"><%= totalMonthlyFees %></span>
    </div>
  </div>
  <div class="footer">
    This is an automated monthly reconciliation report generated by American Surplus Platform.
  </div>
</body>
</html>
