<div style="padding:30px 20px; color:#333;">
    <h2>Hello <%= name %>,</h2>
    <p>
        The following properties were cancelled on <strong><%= cancellationDate %></strong>
        for request <strong><%= tcn || 'N/A' %></strong>
        by <strong><%= canceledByName %></strong> from <strong><%= organizationName %></strong>
        (Donee Account: <%= doneeAccountNumber %>):
    </p>
    <ul>
        <% propertyCancelList.forEach(property => { %>
            <li>
                <strong><%= property.property_name %></strong> (ICN: <%= property.ICN %>) has been cancelled.
                <% if (property.is_late_cancelled) { %>
                    This is a late cancellation.
                <% } %>
                <div>
                    Reason: <%= property.cancellation_reason || cancellationReason %>
                </div>
            </li>
        <% }); %>
    </ul>
    <p>Please review the details and take any necessary actions.</p>
    <p>Thanks,<br />American Surplus</p>
</div>
