<div style="padding:30px 20px; color:#333;">
    <h2>Hello <%= name %>,</h2>
    <p>
        <strong>Attention:</strong> Your eligibility application will expire soon.
    </p>
    <table style="margin:20px 0; border-collapse:collapse;">
        <tr>
            <td style="padding:4px 8px;"><strong>Application ID:</strong></td>
            <td style="padding:4px 8px;"><%= application.id %></td>
        </tr>
        <tr>
            <td style="padding:4px 8px;"><strong>State:</strong></td>
            <td style="padding:4px 8px;"><%= state %></td>
        </tr>
        <tr style="background-color:#fff3cd;">
            <td style="padding:4px 8px;"><strong>Days Until Expiration:</strong></td>
            <td style="padding:4px 8px;"><strong><%= daysUntilExpiry %> days</strong></td>
        </tr>
    </table>
    <div style="background-color:#fff3cd; border:1px solid #ffeaa7; border-radius:4px; padding:15px; margin:20px 0;">
        <p style="margin:0; color:#856404;"><strong>Action Required:</strong> Please log into American Surplus and renew your application before it expires. If no action is taken, you will need to submit a new application.</p>
    </div>
    <p>If you have any questions, please contact us.</p>
    <p>Thanks,<br />American Surplus Team</p>
</div>
