{
  "name": "american-surplus",
  "version": "0.0.1",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "tsc && tsc-alias && npm run copy-files",
    "copy-files": "cp -r src/templates dist/templates && cp -r src/documents/assets/ dist/documents/assets/",
    "dev": "nodemon --exec ts-node src/index.ts",
    "dev:watch": "nodemon --exec ts-node src/index.ts",
    "setup:local": "node scripts/setup-local.cjs",
    "init:local": "node scripts/local-init.cjs",
    "init:local:reset": "node scripts/local-init.cjs --reset",
    "db:sync:local": "node scripts/db-sync-local.cjs",
    "seed:db:local": "node scripts/db-seed-local.cjs",
    "seed:local": "node scripts/seed-local-launcher.cjs",
    "seed:local:status": "node scripts/job-status.cjs --job=seed-local",
    "seed:local:logs": "node scripts/job-logs.cjs --job=seed-local --lines=200",
    "es:sync": "node scripts/es-sync.cjs --mode=replace",
    "es:sync:status": "node scripts/job-status.cjs --job=es-sync",
    "es:sync:logs": "node scripts/job-logs.cjs --job=es-sync --lines=200",
    "patch:sync": "node scripts/patch-sync.cjs",
    "patch:sync:dry-run": "node scripts/patch-sync.cjs --dry-run",
    "patch:audit": "node scripts/patch-audit.cjs",
    "verify:seed-vs-patch": "node scripts/verify-seed-vs-patch.cjs",
    "cdn:hydrate": "node scripts/cdn-hydrate.cjs",
    "cdn:hydrate:async": "node scripts/cdn-hydrate-launcher.cjs",
    "cdn:hydrate:status": "node scripts/job-status.cjs --job=cdn-hydrate",
    "cdn:hydrate:logs": "node scripts/job-logs.cjs --job=cdn-hydrate --lines=200",
    "docker:build": "docker compose down && docker build --build-arg ENVIRONMENT=development . -t american-surplus:api-utopia && docker compose up -d",
    "test": "jest",
    "test:verbose": "jest --verbose",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "test:changed": "jest --onlyChanged",
    "lint": "eslint . --ext .ts --fix",
    "format": "prettier --write ."
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/ejs": "^3.1.5",
    "@types/express": "^4.17.21",
    "@types/ini": "^4.1.0",
    "@types/ioredis": "^4.28.10",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.1",
    "@types/ws": "^8.5.10",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "ts-jest": "^29.2.6",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.10",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.2"
  },
  "dependencies": {
    "@azure/identity": "^4.8.0",
    "@elastic/elasticsearch": "^8.19.1",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@types/multer": "^1.4.12",
    "@types/otplib": "^7.0.0",
    "@types/speakeasy": "^2.0.10",
    "@types/uuid": "^9.0.8",
    "axios": "^1.13.5",
