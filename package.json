    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "decimal.js": "^10.6.0",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "elastic-orm": "github:Twiddlle/elasticsearch-orm",
    "exceljs": "^4.4.0",
    "express": "^4.21.0",
    "express-rate-limit": "^7.2.0",
    "fs-extra": "^11.2.0",
    "ini": "^4.1.2",
    "intuit-oauth": "^4.2.2",
    "ioredis": "^5.6.0",
    "isomorphic-fetch": "^3.0.0",
    "jsonwebtoken": "^9.0.2",
    "kafkajs": "^2.2.4",
    "libphonenumber-js": "^1.12.6",
    "log4js": "^6.9.1",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.11.5",
    "node-cache": "^5.1.2",
    "otplib": "^12.0.1",
    "pdf-lib": "^1.17.1",
    "puppeteer": "^24.10.2",
    "reflect-metadata": "^0.2.2",
